# Scanner Configuration
SCANNER_HOST=vapagelaser.local
SCANNER_TIMEOUT=30s
SCANNER_DUPLEX=true
SCANNER_SOURCE=adf
SCANNER_COLOR=RGB24
SCANNER_REORDER=interleave

# Paperless-ngx Configuration
PAPERLESS_URL=https://paperless.vapage.devxq.com
PAPERLESS_TOKEN=your-api-token-here

# Server Configuration
SERVER_ADDR=:8080

# Filing System
FILING_ENABLED=true
FILING_PAGE_THRESHOLD=50
FILING_PRINTER_HOST=

# Storage
DATABASE_PATH=/data/paperless-airscan.db
TEMP_DIR=/tmp/paperless-airscan
